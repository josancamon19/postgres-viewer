{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Postgres Viewer",
  "version": "0.1.0",
  "identifier": "com.postgresviewer.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Postgres Viewer",
        "width": 1280,
        "height": 840,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "DeveloperTool",
    "shortDescription": "Fast read-only PostgreSQL and Supabase viewer",
    "longDescription": "A fast, read-only desktop viewer for PostgreSQL and Supabase databases.",
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
